# ============================================================
# FriendFinanceAgent 环境变量配置示例
# ============================================================
# 复制本文件为 .env 并填入真实值：
#   copy .env.example .env
# 注意：.env 含密钥，勿提交到版本控制

# --- 飞书 Webhook 通知（可选，用于盘中推送乖离扫盘和资金监控） ---
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-path

# --- 钱脉系统 API（盘后资金流向数据） ---
# 如果您有类似小白的 API 服务，填入地址和 Token
# 没有的话，fund_flow.py 依然可用（盘中实时拉），只是没有历史数据累积
QIANMAI_API_BASE=https://your-server/fund_flow/api
QIANMAI_TOKEN=your-token-here

# --- 同花顺 thsdk（用于 fund_flow.py 盘中主力资金查询） ---
# thsdk 游客账户可能失效，失效时需配正式账号
# 如果游客账户可用，留空即可
THS_ACCOUNT=
THS_PASSWORD=

# --- 本地通达信数据目录（用于 day_kline_analysis.py 本地日K分析） ---
# 如果不使用通达信数据，day_kline_analysis.py 会报错，可跳过
TDX_DATA_DIR=C:\\new_tdx\\vipdoc
